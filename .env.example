# Shop visibility (build-time — redeploy after changing)
SHOW_SHOP=TRUE

# Stripe — catalog, checkout, and webhooks (Netlify env vars)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Local dev: netlify dev → http://localhost:8888
# Webhook forwarding: stripe listen --forward-to localhost:8888/.netlify/functions/stripe-webhook
