# Shop visibility (build-time — redeploy after changing)
SHOW_SHOP=TRUE

# Public site URL — canonical links, sitemap, OG images (no trailing slash)
# Set in Netlify for ALL deploy contexts (production, deploy previews, branch deploys).
SITE_URL=https://jollyzu.com
# Exposed to the frontend at build time (usually same as SITE_URL)
VITE_SITE_URL=https://jollyzu.com

# Stripe — catalog, checkout, and webhooks (Netlify env vars)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Local dev: netlify dev → http://localhost:8888
# Webhook forwarding: stripe listen --forward-to localhost:8888/.netlify/functions/stripe-webhook
